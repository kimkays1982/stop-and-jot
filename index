  border: 1px solid #C5D3F5; border-radius: 5px; padding: 6px 10px;
  margin-bottom: 4px; font-size: 12px; color: #333; background: #fff; cursor: pointer;
}
.jot-starter.selected { background: #EBF0FF; border-color: #3B6FD4; color: #1E3A6E; font-weight: 600; }
.jot-starter-plus { color: #3B6FD4; font-size: 14px; font-weight: 300; }
.jot-input {
  width: 100%; border: 1px solid #C5D3F5; border-radius: 5px; padding: 8px 10px;
  font-size: 12px; color: #333; background: #fff; margin-top: 6px; margin-bottom: 8px;
  resize: none; font-family: inherit; min-height: 44px;
}
.jot-input.filled { color: #1a1a2e; }
.jot-footer { display: flex; align-items: center; justify-content: space-between; }
.jot-lang { font-size: 10px; color: #3B6FD4; display: flex; align-items: center; gap: 3px; }
.jot-skip { font-size: 10px; color: #666; padding: 3px 10px; border: 1px solid #D0D4E4; border-radius: 4px; cursor: pointer; }
.jot-submit { font-size: 10px; color: #fff; background: #3B6FD4; padding: 4px 12px; border-radius: 4px; font-weight: 600; cursor: pointer; }

/* Feedback state */
.jot-feedback {
  background: #EDF7F0; border: 1px solid #A8D8B4; border-radius: 8px;
  padding: 10px 12px; margin: 10px 0;
}
.jot-feedback-header { display: flex; align-items: center; gap: 5px; margin-bottom: 6px; }
.jot-feedback-icon { color: #3BAA6E; font-size: 12px; }
.jot-feedback-label { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #3BAA6E; }
.jot-feedback-text { font-size: 11px; color: #2A5C38; line-height: 1.5; margin-bottom: 8px; }
.jot-feedback-footer { display: flex; align-items: center; justify-content: space-between; }
.jot-feedback-lang { font-size: 10px; color: #3B6FD4; }
.jot-feedback-saved { font-size: 10px; color: #3BAA6E; display: flex; align-items: center; gap: 3px; }
.ext-panel-notice { font-size: 10px; color: #bbb; font-style: italic; padding: 8px 18px 10px; border-top: 1px solid #F0F1F6; background: #fff; }

/* Spanish card */
.jot-card.spanish { background: #FFF8F0; border-color: #F0C895; }
.jot-card.spanish .jot-card-icon { color: #D4780A; }
.jot-card.spanish .jot-card-label { color: #D4780A; }
.jot-card.spanish .jot-question { color: #1a1a2e; }
.jot-card.spanish .jot-mode-tab { border-color: #F0C895; }
.jot-card.spanish .jot-mode-tab.active { background: #D4780A; border-color: #D4780A; }
.jot-card.spanish .jot-starter { border-color: #F0C895; }
.jot-card.spanish .jot-starter.selected { background: #FFF0DC; border-color: #D4780A; color: #7A3C00; }
.jot-card.spanish .jot-input { border-color: #F0C895; }
