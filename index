.dash-title { font-size: 12px; font-weight: 700; color: #1a1a2e; }
.dash-sub { font-size: 10px; color: #aaa; }
.dash-tabs { display: flex; gap: 0; padding: 0 14px; border-bottom: 1px solid #E8EAF2; }
.dash-tab { padding: 7px 12px; font-size: 11px; color: #888; border-bottom: 2px solid transparent; margin-bottom: -1px; }
.dash-tab.active { color: #3B6FD4; border-bottom-color: #3B6FD4; font-weight: 600; }
.dash-section-label { font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #aaa; padding: 10px 14px 5px; }
.dash-tiles { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; padding: 0 14px 10px; }
.dash-tile { border: 1px solid #E8EAF2; border-radius: 6px; padding: 8px 10px; }
.dash-tile-label { font-size: 9px; color: #999; margin-bottom: 3px; }
.dash-tile-value { font-size: 18px; font-weight: 700; color: #1a1a2e; }
.dash-tile.new { border-color: #C5D3F5; background: #F6F8FF; }
.dash-tile.new .dash-tile-label { color: #3B6FD4; }
.dash-new-badge { font-size: 8px; font-weight: 700; background: #3B6FD4; color: #fff; padding: 1px 5px; border-radius: 8px; margin-bottom: 4px; display: inline-block; }
.dash-table { width: 100%; border-collapse: collapse; }
.dash-table th { font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #aaa; padding: 6px 14px; text-align: left; border-bottom: 1px solid #E8EAF2; }
