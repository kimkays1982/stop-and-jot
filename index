.jot-question { font-size: 13px; font-weight: 600; color: #1a1a2e; margin-bottom: 9px; line-height: 1.4; }
.jot-mode-tabs { display: flex; gap: 4px; margin-bottom: 8px; }
.jot-mode-tab {
  flex: 1; text-align: center; padding: 4px 6px; border-radius: 4px;
  border: 1px solid #C5D3F5; font-size: 10px; color: #666; cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 3px;
