.dash-flag { display: inline-flex; align-items: center; gap: 3px; font-size: 10px; color: #E07A2F; margin-left: 6px; }
.dash-notice { font-size: 10px; color: #aaa; padding: 8px 14px; font-style: italic; }

/* Callout cards */
.callout {
  display: flex; gap: 13px; align-items: flex-start;
